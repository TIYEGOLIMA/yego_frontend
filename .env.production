# Producción: API pública (Vite inyecta estas vars en el build; no uses localhost aquí).
VITE_API_URL=https://api-int.yego.pro/api
VITE_SOCKET_URL=https://api-int.yego.pro

VITE_AGENT_API_URL=https://api-int.yego.pro/api/ticketera
VITE_AGENT_SOCKET_URL=https://api-int.yego.pro

VITE_WS_URL=wss://api-int.yego.pro/ws
VITE_STOMP_URL=https://api-int.yego.pro/ws

VITE_APP_NAME=Yego Integral (PROD)
VITE_APP_VERSION=2.0.0
VITE_DEV_MODE=false

VITE_ENABLE_LOGS=false
VITE_ENABLE_DEBUG=false
VITE_LOG_LEVEL=error
VITE_ENABLE_DEVTOOLS=false

VITE_API_TIMEOUT=30000
VITE_RECONNECT_ATTEMPTS=5
VITE_RECONNECT_DELAY=3000

# Control Tower (HTTPS si Integral es HTTPS)
VITE_CONTROL_TOWER_URL=https://5.161.86.63
