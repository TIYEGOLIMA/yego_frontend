# =====================================================
# YEGO INTEGRAL FRONTEND - CONFIGURACIÓN DE VARIABLES DE ENTORNO
# =====================================================

# 🟦 SISTEMA PRINCIPAL (Sin prefijo /ticketera)
# Para: Login, usuarios, roles, configuración general
VITE_API_URL=http://localhost:3030/api
VITE_SOCKET_URL=http://localhost:3030
VITE_WS_URL=ws://localhost:3030

# 🟨 MICROFRONTENDS TICKETERA (Con prefijo /ticketera) 
# Para: Tickets, módulos de atención, colas específicas
VITE_AGENT_API_URL=http://localhost:3030/api/ticketera
VITE_AGENT_SOCKET_URL=http://localhost:3030

# 🚀 CONFIGURACIÓN DE APLICACIÓN
VITE_APP_NAME=Yego Integral
VITE_APP_VERSION=2.0.0

# Variables de entorno para producción
# VITE_API_URL=https://api.yego.com/api
# VITE_AGENT_API_URL=https://api.yego.com/api/ticketera
# VITE_WS_URL=wss://api.yego.com
# VITE_APP_NAME=Yego Integral
# VITE_APP_VERSION=2.0.0

# 🌐 WEBSOCKETS (Sistema unificado)
VITE_STOMP_URL=http://localhost:3030/ws

# Configuración de la aplicación
VITE_APP_DESCRIPTION=Sistema Integral de Gestión YEGO

# Configuración de desarrollo
VITE_DEV_MODE=true
VITE_ENABLE_LOGS=true
VITE_ENABLE_DEBUG=true

# 🔧 Configuración de desarrollo avanzada
VITE_API_TIMEOUT=30000
VITE_RECONNECT_ATTEMPTS=5
VITE_RECONNECT_DELAY=3000

# 🌍 Configuración de localización
VITE_LOCALE=es-PE
VITE_TIMEZONE=America/Lima

# 📊 Configuración de métricas y análisis
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_TRACKING=false

# 🔒 Configuración de seguridad
VITE_ENABLE_SECURITY_HEADERS=true
VITE_CSP_ENABLED=false

# 📱 Configuración PWA
VITE_PWA_ENABLED=false
VITE_OFFLINE_SUPPORT=false

# 🎨 Configuración de UI
VITE_THEME_MODE=system
VITE_ANIMATIONS_ENABLED=true

# ⚡ Configuración de performance
VITE_LAZY_LOADING=true
VITE_PREFETCH_ENABLED=true
VITE_CACHE_DURATION=300000

# 🧪 Configuración de testing
VITE_MOCK_API=false
VITE_TESTING_MODE=false

# 📝 Configuración de logs
VITE_LOG_LEVEL=info
VITE_LOG_TO_CONSOLE=true
VITE_LOG_TO_SERVER=false