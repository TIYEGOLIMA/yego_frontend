# =====================================================
# YEGO INTEGRAL FRONTEND - CONFIGURACIÓN DE VARIABLES DE ENTORNO
# =====================================================

# Variables de entorno para desarrollo
# Backend NestJS (Sistema principal)
VITE_API_URL=http://localhost:3000/api
VITE_SOCKET_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000
VITE_APP_NAME=Yego Integral
VITE_APP_VERSION=2.0.0

# Variables de entorno para producción
# VITE_API_URL=https://api.yego.com/api
# VITE_WS_URL=wss://api.yego.com
# VITE_APP_NAME=Yego Integral
# VITE_APP_VERSION=2.0.0

# Configuración de la API (Backend NestJS - Sistema principal)
VITE_API_URL=http://localhost:3000/api

# Configuración de WebSockets (Socket.IO)  
VITE_SOCKET_URL=http://localhost:3000

# Configuración del AgentPanel (Sistema de ticketera independiente)
VITE_AGENT_API_URL=http://5.161.86.63:3030/api
VITE_AGENT_SOCKET_URL=http://5.161.86.63:3030

# Configuración de la aplicación
VITE_APP_DESCRIPTION=Sistema Integral de Gestión YEGO

# Configuración de desarrollo
VITE_DEV_MODE=true
VITE_ENABLE_LOGS=true
VITE_ENABLE_DEBUG=true

# Configuración de autenticación
VITE_AUTH_STORAGE_KEY=yego_auth
VITE_SESSION_STORAGE_KEY=yego_session

# Configuración de notificaciones
VITE_ENABLE_NOTIFICATIONS=true
VITE_NOTIFICATION_DURATION=5000

# Configuración de temas
VITE_DEFAULT_THEME=light
VITE_ENABLE_DARK_MODE=true

# Configuración de idiomas
VITE_DEFAULT_LANGUAGE=es
VITE_AVAILABLE_LANGUAGES=es,en

# Configuración de archivos
VITE_MAX_FILE_SIZE=10485760
VITE_ALLOWED_FILE_TYPES=csv,xlsx,xls

# Configuración de paginación
VITE_DEFAULT_PAGE_SIZE=20
VITE_MAX_PAGE_SIZE=100

# Configuración de cache
VITE_CACHE_DURATION=300000
VITE_ENABLE_CACHE=true

# Configuración de analytics (opcional)
VITE_ANALYTICS_ID=
VITE_ENABLE_ANALYTICS=false

# Configuración de monitoreo de errores (opcional)
VITE_SENTRY_DSN=
VITE_ENABLE_ERROR_TRACKING=false

# Configuración de PWA
VITE_ENABLE_PWA=false
VITE_PWA_NAME=Yego Integral
VITE_PWA_SHORT_NAME=Yego
VITE_PWA_DESCRIPTION=Sistema Integral de Gestión YEGO

# Configuración de mapas (opcional)
VITE_MAPS_API_KEY=
VITE_ENABLE_MAPS=false

# Configuración de notificaciones push (opcional)
VITE_PUSH_PUBLIC_KEY=
VITE_ENABLE_PUSH_NOTIFICATIONS=false 