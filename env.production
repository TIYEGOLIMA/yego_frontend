# =====================================================
# YEGO INTEGRAL - CONFIGURACIÓN DE PRODUCCIÓN
# =====================================================

# 🟦 SISTEMA PRINCIPAL (Sin prefijo) - Login, usuarios, configuración
VITE_API_URL=https://api-int.yego.pro/api
VITE_SOCKET_URL=https://api-int.yego.pro

# 🟨 MICROFRONTENDS TICKETERA (Con prefijo) - Tickets, módulos, colas
VITE_AGENT_API_URL=https://api-int.yego.pro/api/ticketera
VITE_AGENT_SOCKET_URL=https://api-int.yego.pro

# 🌐 WEBSOCKETS (Sistema unificado)
VITE_WS_URL=wss://api-int.yego.pro/ws
VITE_STOMP_URL=https://api-int.yego.pro/ws

# 🔔 WEBSOCKET NOTIFICACIONES DEL SISTEMA
VITE_SYSTEM_WS_URL=wss://api-int.yego.pro/ws

# 🚀 CONFIGURACIÓN DE APLICACIÓN
VITE_APP_NAME=Yego Integral (PROD)
VITE_APP_VERSION=2.0.0
VITE_DEV_MODE=false

# 📊 DEBUG Y LOGS DESHABILITADOS PARA PRODUCCIÓN
VITE_ENABLE_LOGS=false
VITE_ENABLE_DEBUG=false
VITE_LOG_LEVEL=error
VITE_ENABLE_DEVTOOLS=false

# 🔧 CONFIGURACIÓN DE TIMEOUTS Y RECONEXIÓN
VITE_API_TIMEOUT=30000
VITE_RECONNECT_ATTEMPTS=5
VITE_RECONNECT_DELAY=3000

# 🔐 TOKEN DE AUTENTICACIÓN
VITE_AUTH_TOKEN=2368f3693c87e07f24f729e8bcb9213d
